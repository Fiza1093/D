-- Trigger to validate GPA
DELIMITER //

CREATE TRIGGER CHECK_GPA
BEFORE INSERT ON STUDENT
FOR EACH ROW
BEGIN
    IF NEW.GPA <= 0 THEN
        SET NEW.GPA = NULL;
    END IF;
END;
//

DELIMITER ;
